<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /rms/
    
    # Remove index.php from URLs
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?/$1 [L,QSA]
</IfModule>

# Disable directory browsing
Options -Indexes

# Default index files
DirectoryIndex index.php index.html
